# ============================================
# RENDER DEPLOYMENT ENV VARIABLES
# ============================================

# The URL of your live Vercel frontend (e.g., https://gowtham-paints.vercel.app)
FRONTEND_URL=http://localhost:5173

# Database configuration (Get these from your Aiven / Railway dashboard)
DB_HOST=your_database_host
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name
DB_PORT=25060
DB_SSL=true

# Port for Render (Render will usually provide this automatically, but good to have)
PORT=5000
